{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Jekyll Serve",
			"type": "shell",
			"command": "bundle exec jekyll serve --livereload --host 127.0.0.1",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": false
			}
		}
	]
}